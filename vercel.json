{
  "outputDirectory": "dist",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/policy-lines/:path*",      "destination": "/policy-lines/index.html" },
    { "source": "/uk-gov-network-graph/:path*", "destination": "/uk-gov-network-graph/index.html" },
    { "source": "/smile",                    "destination": "https://smile-two-theta.vercel.app" },
    { "source": "/smile/:path*",             "destination": "https://smile-two-theta.vercel.app/:path*" }
  ]
}
